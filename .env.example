# GMGN Screener + Auto Trader
# Copy to .env and fill in your values

# ─── Solana RPC ───────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# ─── Jupiter Swap API ─────────────────────────────────
JUPITER_API_URL=https://api.jup.ag/swap/v1
JUPITER_API_KEY=your_jupiter_api_key

# ─── Telegram Bot ─────────────────────────────────────
BOT_TOKEN=your_bot_token_here
CHAT_ID=your_chat_id_here
BOT_USERNAME=your_bot_username_without_at

# ─── Helius API (for bundler detection) ──────────────
HELIUS_API_KEY=your_helius_api_key

# ─── GMGN API ─────────────────────────────────────────
GMGN_API_KEY=your_gmgn_api_key_here

# ─── Wallet (optional — can also import via /wallet import) ───
# WALLET_PRIVATE_KEY=your_base58_private_key

# Whitelist (comma-separated chat IDs, empty = allow all)
ALLOWED_CHAT_IDS=your_chat_id
